<?php
session_start();
require('connection.inc.php');
require('functions.inc.php');
$msg='';

if(!isset($_SESSION['password_reset_email_send'])){
	$_SESSION['password_reset_email_send'] = 0;
}

$user_id = get_user($conn)[0]; $loggedin = get_user($conn)[1];

if(isset($_POST['reset_password']))
{
	if(isset($_POST['email'])){

		$email = $_POST['email'];

		$sql = "SELECT username from customers where username = '$email'";

		$rows = mysqli_num_rows(mysqli_query($conn, $sql));

		if($rows > 0)
		{
		  	$token = bin2hex(random_bytes(50));
		    if(SendPasswordResetMail($email, $token))
		    {
			    $created_on = crt_time();
			    $sql="insert into password_reset(username,created_at, reset_token, used) values('$email','$created_on','$token', 0)";
ysqli_query($conn, $sql)){
					$_SESSION['password_reset_email_send'] = 1;
				//	header('location:'.SITE_PATH.'forgot_password ');
				}

				else
					$msg = "Can't Connect the the server... Please try later";
			}
			else
				$msg = "Can't Connect the the server... Please try later";
			
		}
		else
			$msg = "No Accounts found with E-Mail Address ".$email;
    }
}

$password_reset_email_send = $_SESSION['password_reset_email_send'];

